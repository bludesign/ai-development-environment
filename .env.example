# Database connection string.
#
# Local development defaults to a SQLite file (no server required). The runtime client and the
# Prisma CLI both read DATABASE_URL; the driver adapter is selected by the URL scheme.
DATABASE_URL="file:./prisma/dev.db"

# To use an external Postgres database instead, set a postgres:// URL and follow the provider
# switch steps in the README (change the schema.prisma provider + re-baseline migrations):
#   DATABASE_URL="postgresql://user:password@localhost:5432/ai_development_environment"

# Enable the Apollo sandbox + GraphQL introspection in production-like runs (optional).
# APOLLO_SANDBOX=true

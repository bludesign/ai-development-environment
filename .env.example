# Database connection string.
#
# This build supports SQLite only. The runtime client and Prisma CLI both read DATABASE_URL.
DATABASE_URL="file:./prisma/dev.db"

# GraphQL WebSocket listener used by macOS agents and the live-output UI.
# AGENT_WS_HOSTNAME=127.0.0.1
# AGENT_WS_PORT=3091

# Browser-visible WebSocket URL when the control plane is behind a proxy or uses a non-default port.
# NEXT_PUBLIC_AGENT_WS_URL="wss://control-plane.example.com/graphql"

# Enable the Apollo sandbox + GraphQL introspection in production-like runs (optional).
# APOLLO_SANDBOX=true

# Comma-separated list of extra origins allowed by the Next.js dev server (optional).
# Localhost, the machine hostname, and LAN IPs are already allowed by default.
# ALLOWED_DEV_ORIGINS="dev.example.com,10.0.0.50"

# Database connection string.
#
# This build supports SQLite only. The runtime client and Prisma CLI both read DATABASE_URL.
DATABASE_URL="file:./prisma/dev.db"

# GraphQL WebSocket listener used by macOS agents and the live-output UI.
# AGENT_WS_HOSTNAME=127.0.0.1
# AGENT_WS_PORT=3091

# Browser-visible WebSocket URL when the control plane is behind a proxy or uses a non-default port.
# NEXT_PUBLIC_AGENT_WS_URL="wss://control-plane.example.com/graphql"

# Optional one-command development overrides. `npm run dev:all` otherwise uses HTTP port 3000,
# WebSocket port 3092, and a separate config under control-agent-dev.
# CONTROL_AGENT_DEV_SERVER="http://127.0.0.1:3000"
# CONTROL_AGENT_DEV_WEBSOCKET_SERVER="ws://127.0.0.1:3092/graphql"
# CONTROL_AGENT_DEV_CONFIG="/absolute/path/to/dev-agent-config.json"

# Public origin used to build iOS device-enrollment and over-the-air install URLs
# when forwarded headers do not already describe the address devices use. iOS
# requires publicly trusted HTTPS for enrollment callbacks, install manifests,
# and packages, so those features are offered only when this resolves to https.
#
# Exposing this server publicly exposes every route, not just build artifacts.
# With Cloudflare Access, bypass authentication only for:
#   /api/ios/enrollment-profile
#   /api/ios/profile-response
#   /api/ios/enrollment-complete
#   /api/builds/*/artifacts/*
# Keep /devices, /api/ios/enrollment/start, and /api/graphql authenticated.
# Access application paths must not contain query strings.
# PUBLIC_BASE_URL="https://builds.example.com"

# Secret used to sign short-lived iOS install download links. A random per-process
# value is used when unset, which invalidates outstanding links on restart.
# OTA_TOKEN_SECRET="a-long-random-string"

# Where downloaded build artifacts are cached, and how much room they may take.
# Installing over the air re-reads the package several times, so it is fetched
# from the agent once and served locally afterwards. Defaults to the temporary
# directory and 5 GiB.
# ARTIFACT_CACHE_DIRECTORY="/var/tmp/ade-build-artifact-cache"
# ARTIFACT_CACHE_MAX_BYTES=5368709120

# Enable the Apollo sandbox + GraphQL introspection in production-like runs (optional).
# APOLLO_SANDBOX=true

# Comma-separated list of extra origins allowed by the Next.js dev server (optional).
# Localhost, the machine hostname, and LAN IPs are already allowed by default.
# ALLOWED_DEV_ORIGINS="dev.example.com,10.0.0.50"

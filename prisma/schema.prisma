// Prisma schema — https://pris.ly/d/prisma-schema
//
// Uses the Prisma 7 `prisma-client` generator (TypeScript query compiler, no Rust engine
// binary) with driver adapters, so the generated client bundles cleanly into the Next.js
// `standalone` output that the Homebrew service runs.
//
// The application currently supports SQLite only. DATABASE_URL controls the file location;
// src/data/prisma-client.ts rejects other URL schemes before constructing the adapter.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Agent {
  id                       String                     @id
  name                     String
  hostname                 String
  version                  String
  osVersion                String
  architecture             String
  cpuModel                 String?
  memoryTotalBytes         Float?
  memoryFreeBytes          Float?
  diskTotalBytes           Float?
  diskFreeBytes            Float?
  capabilitiesJson         String
  secretHash               String                     @unique
  baseRepoDirectory        String?
  derivedDataLocationMode  String                     @default("DEFAULT")
  derivedDataPath          String?
  buildsDirectory          String?
  defaultBuildsDirectory   String?
  ipAddress                String?
  lastSeenAt               DateTime?
  disconnectedAt           DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  jobs                     AgentJob[]
  ccusageCollections       CcusageCollectionAgent[]
  auditEvents              AgentAuditEvent[]
  codebases                Codebase[]
  buildDataCollections     BuildDataCollectionAgent[]
  buildDataDeletionHistory BuildDataDeletionHistory[]
  skillToolObservations    SkillToolObservation[]
  skillInstallations       SkillInstallation[]
  skillDeployments         SkillDeployment[]
  skillSyncItems           SkillSyncItem[]
  builds                   Build[]
}

model AgentEnrollmentToken {
  id        String    @id
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model IosDevice {
  id                String                   @id
  udid              String                   @unique
  displayName       String
  product           String?
  osVersion         String?
  platform          String                   @default("IOS")
  status            String                   @default("PENDING")
  appleDeviceId     String?                  @unique
  appleStatus       String?
  registrationError String?
  registrationClaimedAt DateTime?
  registeredAt      DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  enrollments       IosDeviceEnrollment[]
  ipObservations    IosDeviceIpObservation[]

  @@index([status, createdAt])
  @@index([lastSeenAt])
}

model IosDeviceEnrollment {
  id             String                   @id
  deviceId       String?
  tokenHash      String                   @unique
  displayName    String
  status         String                   @default("ISSUED")
  expiresAt      DateTime
  downloadedAt   DateTime?
  consumedAt     DateTime?
  responseDigest String?
  failureCode    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  device         IosDevice?               @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  ipObservations IosDeviceIpObservation[]

  @@index([deviceId, createdAt])
  @@index([status, expiresAt])
}

model IosDeviceIpObservation {
  id           String              @id
  deviceId     String?
  enrollmentId String
  ipAddress    String
  source       String
  headerSource String
  observedAt   DateTime            @default(now())
  device       IosDevice?          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  enrollment   IosDeviceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, source, ipAddress])
  @@index([deviceId, observedAt])
  @@index([enrollmentId, observedAt])
}

model IosDeviceSettings {
  id                                  String    @id
  organizationName                    String    @default("AI Development Environment")
  profileIdentifier                   String    @default("com.ai-development-environment.device-enrollment")
  signerCertificatePem                String?
  signerPrivateKeyPem                 String?
  signerFingerprint                   String?
  signerCreatedAt                     DateTime?
  signerExpiresAt                     DateTime?
  appStoreConnectIssuerId             String?
  appStoreConnectKeyId                String?
  appStoreConnectPrivateKey           String?
  appStoreConnectPrivateKeyFingerprint String?
  appStoreConnectVerifiedAt           DateTime?
  appStoreConnectLastTestedAt         DateTime?
  appStoreConnectVerificationError    String?
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime  @updatedAt
}

model AgentJob {
  id                    String               @id
  agentId               String
  kind                  String
  payloadJson           String
  status                String
  idempotencyKey        String
  resultJson            String?
  error                 String?
  timeoutSeconds        Int
  createdAt             DateTime             @default(now())
  startedAt             DateTime?
  finishedAt            DateTime?
  updatedAt             DateTime             @updatedAt
  ccusageCollectionId   String?
  buildDataCollectionId String?
  codebaseId            String?
  worktreeId            String?
  visibility            String               @default("USER")
  agent                 Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ccusageCollection     CcusageCollection?   @relation(fields: [ccusageCollectionId], references: [id], onDelete: SetNull)
  buildDataCollection   BuildDataCollection? @relation(fields: [buildDataCollectionId], references: [id], onDelete: SetNull)
  codebase              Codebase?            @relation(fields: [codebaseId], references: [id], onDelete: SetNull)
  logs                  AgentJobLog[]
  builds                Build[]
  deployments           BuildDeployment[]
  exports               BuildExport[]

  @@unique([agentId, idempotencyKey])
  @@index([agentId, status, createdAt])
  @@index([ccusageCollectionId, status])
  @@index([buildDataCollectionId, status])
  @@index([codebaseId, status, createdAt])
  @@index([worktreeId, status, createdAt])
}

model CodebaseRepository {
  id                     String                          @id
  canonicalOrigin        String                          @unique
  displayOrigin          String
  name                   String
  description            String                          @default("")
  jiraBranchRegex        String?
  keepBaseBranchUpToDate Boolean                         @default(true)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  codebases              Codebase[]
  skillGroups            CodebaseRepositorySkillGroup[]
  projects               CodebaseProject[]
  buildScripts           CodebaseRepositoryBuildScript[]

  @@index([name])
}

model Codebase {
  id                 String                   @id
  repositoryId       String
  agentId            String
  folder             String
  observedOrigin     String
  branch             String?
  headSha            String?
  upstream           String?
  ahead              Int?
  behind             Int?
  syncState          String                   @default("UNKNOWN")
  availability       String                   @default("AVAILABLE")
  statusError        String?
  defaultBranch      String?
  localBranchesJson  String                   @default("[]")
  remoteBranchesJson String                   @default("[]")
  lastCheckedAt      DateTime?
  lastFetchedAt      DateTime?
  lastFetchAttemptAt DateTime?
  lastFetchError     String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  repository         CodebaseRepository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  agent              Agent                    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  jobs               AgentJob[]
  worktrees          Worktree[]
  skillInstallations SkillInstallation[]
  skillDeployments   SkillDeployment[]
  sourceObservations BuildSourceObservation[]
  builds             Build[]

  @@unique([agentId, folder])
  @@index([repositoryId])
  @@index([agentId, availability])
}

model CodebaseSettings {
  id                     String   @id
  refreshIntervalSeconds Int      @default(30)
  fetchIntervalSeconds   Int      @default(300)
  defaultJiraBranchRegex String   @default("\\b([A-Z][A-Z0-9_]*-\\d+)\\b")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Worktree {
  id                       String                     @id
  codebaseId               String
  gitDirectory             String
  folder                   String
  relativePath             String
  primary                  Boolean                    @default(false)
  branch                   String?
  headSha                  String?
  codeStateHash            String?
  upstream                 String?
  ahead                    Int?
  behind                   Int?
  syncState                String                     @default("UNKNOWN")
  baseBranchOverride       String?
  baseAhead                Int?
  baseBehind               Int?
  hasStagedChanges         Boolean                    @default(false)
  hasUnstagedChanges       Boolean                    @default(false)
  pushStatus               String                     @default("UNKNOWN")
  highlightColor           String?
  availability             String                     @default("AVAILABLE")
  statusError              String?
  lastCheckedAt            DateTime?
  missingAt                DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  codebase                 Codebase                   @relation(fields: [codebaseId], references: [id], onDelete: Cascade)
  tags                     WorktreeTagAssignment[]
  buildDataDeletionHistory BuildDataDeletionHistory[]
  skillInstallations       SkillInstallation[]
  skillDeployments         SkillDeployment[]
  sourceObservations       BuildSourceObservation[]
  builds                   Build[]

  @@unique([codebaseId, gitDirectory])
  @@index([codebaseId, missingAt])
  @@index([missingAt])
}

model Skill {
  id            String              @id
  name          String              @unique
  description   String
  syncGlobally  Boolean             @default(true)
  packageHash   String
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  files         SkillFile[]
  groups        SkillGroupSkill[]
  installations SkillInstallation[]
  baselines     SkillSyncBaseline[]
  deployments   SkillDeployment[]
  syncItems     SkillSyncItem[]

  @@index([name])
  @@index([deletedAt, updatedAt])
}

model SkillFile {
  id          String   @id
  skillId     String
  path        String
  contents    Bytes
  executable  Boolean  @default(false)
  contentHash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  skill       Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, path])
  @@index([skillId])
}

model SkillGroup {
  id           String                         @id
  name         String                         @unique
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt
  skills       SkillGroupSkill[]
  repositories CodebaseRepositorySkillGroup[]
  syncRuns     SkillSyncRun[]

  @@index([name])
}

model SkillGroupSkill {
  groupId String
  skillId String
  group   SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  skill   Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([groupId, skillId])
  @@index([skillId])
}

model CodebaseRepositorySkillGroup {
  repositoryId String
  groupId      String
  repository   CodebaseRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  group        SkillGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([repositoryId, groupId])
  @@index([groupId])
}

model SkillSettings {
  id                    String   @id
  autoSyncProjectGroups Boolean  @default(false)
  cursorEnabled         Boolean  @default(true)
  githubCopilotEnabled  Boolean  @default(true)
  codexEnabled          Boolean  @default(true)
  claudeEnabled         Boolean  @default(true)
  openCodeEnabled       Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SkillToolObservation {
  agentId    String
  tool       String
  configured Boolean  @default(false)
  homePath   String
  checkedAt  DateTime
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([agentId, tool])
  @@index([tool, configured])
}

model SkillInstallation {
  id            String             @id
  skillId       String?
  agentId       String
  codebaseId    String?
  worktreeId    String?
  scope         String
  rootKind      String
  rootPath      String
  skillName     String
  description   String
  packageHash   String
  present       Boolean            @default(true)
  fileCount     Int
  totalBytes    Int
  tracked       Boolean            @default(false)
  consumersJson String             @default("[]")
  lastSeenAt    DateTime
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  skill         Skill?             @relation(fields: [skillId], references: [id], onDelete: SetNull)
  agent         Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  codebase      Codebase?          @relation(fields: [codebaseId], references: [id], onDelete: Cascade)
  worktree      Worktree?          @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  baseline      SkillSyncBaseline?
  syncItems     SkillSyncItem[]

  @@unique([agentId, rootPath, skillName])
  @@index([skillName, packageHash])
  @@index([agentId, lastSeenAt])
  @@index([codebaseId])
  @@index([worktreeId])
}

model SkillSyncBaseline {
  id             String            @id
  installationId String            @unique
  skillId        String
  packageHash    String
  syncedAt       DateTime          @default(now())
  installation   SkillInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  skill          Skill             @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
}

model SkillDeployment {
  id            String    @id
  skillId       String
  agentId       String
  codebaseId    String?
  worktreeId    String?
  scope         String
  rootKind      String
  targetPath    String
  desiredHash   String
  installedHash String?
  status        String    @default("PENDING")
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  skill         Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  codebase      Codebase? @relation(fields: [codebaseId], references: [id], onDelete: Cascade)
  worktree      Worktree? @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@unique([agentId, targetPath])
  @@index([skillId, status])
  @@index([codebaseId])
  @@index([worktreeId])
}

model SkillSyncRun {
  id         String          @id
  kind       String
  groupId    String?
  automatic  Boolean         @default(false)
  status     String
  error      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  finishedAt DateTime?
  group      SkillGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  items      SkillSyncItem[]

  @@index([status, createdAt])
  @@index([groupId, createdAt])
}

model SkillSyncItem {
  id                   String             @id
  runId                String
  skillId              String?
  installationId       String?
  agentId              String?
  direction            String
  status               String
  sourceHash           String?
  targetHash           String?
  resolution           String?
  candidatePackageJson String?
  error                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  run                  SkillSyncRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  skill                Skill?             @relation(fields: [skillId], references: [id], onDelete: SetNull)
  installation         SkillInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)
  agent                Agent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([runId, status])
  @@index([skillId])
  @@index([agentId])
}

model CodebaseProject {
  id             String               @id
  repositoryId   String
  type           String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  repository     CodebaseRepository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sources        BuildSource[]
  configurations BuildConfiguration[]

  @@unique([repositoryId, type])
  @@index([repositoryId])
}

model BuildSource {
  id             String                   @id
  projectId      String
  kind           String
  relativePath   String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  project        CodebaseProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  configurations BuildConfiguration[]
  observations   BuildSourceObservation[]

  @@unique([projectId, relativePath])
  @@index([projectId])
}

model BuildSourceObservation {
  id                 String      @id
  sourceId           String
  scopeKey           String
  codebaseId         String?
  worktreeId         String?
  status             String
  schemesJson        String      @default("[]")
  configurationsJson String      @default("[]")
  testPlansJson      String      @default("[]")
  error              String?
  stale              Boolean     @default(false)
  headSha            String?
  xcodeVersion       String?
  lastParseAttemptAt DateTime
  lastParsedAt       DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  source             BuildSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  codebase           Codebase?   @relation(fields: [codebaseId], references: [id], onDelete: Cascade)
  worktree           Worktree?   @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@unique([sourceId, scopeKey])
  @@index([codebaseId])
  @@index([worktreeId])
}

model BuildConfiguration {
  id                   String          @id
  projectId            String
  sourceId             String
  name                 String
  iconKey              String?
  scheme               String
  buildConfiguration   String
  defaultAction        String          @default("BUILD")
  advancedSettingsJson String          @default("{}")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  project              CodebaseProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source               BuildSource     @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  builds               Build[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([sourceId])
}

model BuildScript {
  id               String                          @id
  name             String                          @unique
  preBuildScript   String?
  postBuildScript  String?
  enabledByDefault Boolean                         @default(false)
  timeoutSeconds   Int                             @default(300)
  failureBehavior  String                          @default("FAIL_BUILD")
  deletedAt        DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  repositories     CodebaseRepositoryBuildScript[]
  executions       BuildScriptExecution[]

  @@index([deletedAt, name])
}

model CodebaseRepositoryBuildScript {
  repositoryId String
  scriptId     String
  position     Int                @default(0)
  repository   CodebaseRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  script       BuildScript        @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@id([repositoryId, scriptId])
  @@index([scriptId])
}

model Build {
  id                String                 @id
  requestKey        String                 @unique
  requestId         String
  agentId           String?
  codebaseId        String?
  worktreeId        String?
  configurationId   String?
  jobId             String?
  status            String                 @default("QUEUED")
  action            String
  destinationType   String
  destinationJson   String
  snapshotJson      String
  commandSummary    String
  artifactDirectory String
  errorCode         String?
  error             String?
  createdAt         DateTime               @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  updatedAt         DateTime               @updatedAt
  agent             Agent?                 @relation(fields: [agentId], references: [id], onDelete: SetNull)
  codebase          Codebase?              @relation(fields: [codebaseId], references: [id], onDelete: SetNull)
  worktree          Worktree?              @relation(fields: [worktreeId], references: [id], onDelete: SetNull)
  configuration     BuildConfiguration?    @relation(fields: [configurationId], references: [id], onDelete: SetNull)
  job               AgentJob?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  artifacts         BuildArtifact[]
  scriptExecutions  BuildScriptExecution[]
  logs              BuildLogEvent[]
  deployments       BuildDeployment[]
  exports           BuildExport[]
  reports           BuildReport[]

  @@index([status, createdAt])
  @@index([agentId, createdAt])
  @@index([codebaseId, createdAt])
  @@index([worktreeId, createdAt])
  @@index([jobId])
}

model BuildArtifact {
  id           String   @id
  buildId      String
  kind         String
  relativePath String
  sizeBytes    Float?
  checksum     String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  build        Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  report       BuildReport?

  @@unique([buildId, relativePath])
  @@index([buildId, kind])
}

model BuildReport {
  id                   String         @id
  buildId              String
  artifactId           String?        @unique
  kind                 String
  source               String
  status               String         @default("PENDING")
  summaryJson          String         @default("{}")
  dataJson             String         @default("{}")
  error                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  finishedAt           DateTime?
  build                Build          @relation(fields: [buildId], references: [id], onDelete: Cascade)
  artifact             BuildArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@unique([buildId, kind])
  @@index([kind, status, createdAt])
  @@index([buildId, createdAt])
}

model BuildScriptExecution {
  id                 String       @id
  buildId            String
  scriptId           String?
  phase              String
  position           Int
  nameSnapshot       String
  sourceSnapshot     String
  timeoutSeconds     Int
  failureBehavior    String
  status             String       @default("PENDING")
  exitCode           Int?
  durationMs         Int?
  causedBuildFailure Boolean      @default(false)
  outputRelativePath String?
  error              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  build              Build        @relation(fields: [buildId], references: [id], onDelete: Cascade)
  script             BuildScript? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@unique([buildId, phase, position])
  @@index([buildId, phase])
}

model BuildLogEvent {
  id        String   @id
  buildId   String
  scope     String
  scopeId   String
  sequence  Int
  phase     String
  level     String
  stream    String
  message   String
  createdAt DateTime @default(now())
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([scope, scopeId, sequence])
  @@index([buildId, createdAt])
}

model TelemetryEntry {
  id                       String   @id
  entryType                String
  clientTime               DateTime
  receivedAt               DateTime @default(now())
  deviceIp                 String?
  message                  String?
  level                    String?
  category                 String?
  eventName                String?
  eventKind                String?
  screenName               String?
  buildId                  String?
  sessionId                String?
  attributesJson           String   @default("{}")
  defaultParametersJson    String   @default("{}")
  additionalParametersJson String   @default("{}")
  searchText               String   @default("")
  highlightColor           String?
  separatorKind            String?
  separatorName            String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([separatorKind, buildId])
  @@index([entryType, clientTime, receivedAt])
  @@index([clientTime, receivedAt])
  @@index([level])
  @@index([category])
  @@index([eventKind])
  @@index([eventName])
  @@index([deviceIp])
  @@index([buildId])
  @@index([sessionId])
}

model TelemetrySettings {
  id                         String   @id
  localBaseUrlOverride       String?
  remoteBaseUrlOverride      String?
  consoleCollectionEnabled   Boolean  @default(true)
  analyticsCollectionEnabled Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model TelemetryViewSettings {
  id                   String   @id
  view                 String   @unique
  columnsJson          String
  timeFormat           String   @default("12")
  activeColumnPresetId String?
  activeSavedFilterId  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model TelemetryColumnPreset {
  id             String   @id
  view           String
  name           String
  normalizedName String
  columnsJson    String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([view, normalizedName])
  @@index([view, isDefault, name])
}

model TelemetrySavedFilter {
  id             String   @id
  view           String
  name           String
  normalizedName String
  definitionJson String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([view, normalizedName])
  @@index([view, name])
}

model BuildDeployment {
  id                 String    @id
  buildId            String
  batchId            String
  requestId          String
  jobId              String?
  destinationJson    String
  destinationKey     String
  status             String    @default("QUEUED")
  commandSummary     String
  outputRelativePath String?
  error              String?
  createdAt          DateTime  @default(now())
  startedAt          DateTime?
  finishedAt         DateTime?
  updatedAt          DateTime  @updatedAt
  build              Build     @relation(fields: [buildId], references: [id], onDelete: Cascade)
  job                AgentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([buildId, requestId, destinationKey])
  @@index([buildId, createdAt])
  @@index([jobId])
}

model BuildExport {
  id                   String    @id
  buildId              String
  requestId            String
  jobId                String?
  status               String    @default("QUEUED")
  settingsSnapshotJson String
  commandSummary       String
  outputRelativePath   String?
  error                String?
  createdAt            DateTime  @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?
  updatedAt            DateTime  @updatedAt
  build                Build     @relation(fields: [buildId], references: [id], onDelete: Cascade)
  job                  AgentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([buildId, requestId])
  @@index([buildId, createdAt])
  @@index([jobId])
}

model BuildDataCollection {
  id         String                     @id
  deadlineAt DateTime
  finishedAt DateTime?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  agents     BuildDataCollectionAgent[]
  jobs       AgentJob[]

  @@index([finishedAt, deadlineAt])
}

model BuildDataCollectionAgent {
  collectionId  String
  agentId       String
  initialStatus String
  error         String?
  collection    BuildDataCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  agent         Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([collectionId, agentId])
  @@index([agentId])
}

model BuildDataDeletionHistory {
  id           String    @id
  agentId      String?
  agentName    String
  folderName   String
  worktreeId   String?
  worktreePath String?
  source       String
  jobId        String
  targetKey    String
  deletedAt    DateTime  @default(now())
  agent        Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  worktree     Worktree? @relation(fields: [worktreeId], references: [id], onDelete: SetNull)

  @@unique([jobId, targetKey])
  @@index([deletedAt])
  @@index([agentId, deletedAt])
}

model BuildDataDeleteProjection {
  jobId       String   @id
  error       String?
  projectedAt DateTime @default(now())
}

model WorktreeMove {
  id               String    @id
  requestId        String
  sourceWorktreeId String
  sourceCodebaseId String
  targetCodebaseId String
  targetWorktreeId String?
  destinationMode  String
  branch           String
  headSha          String
  baseBranch       String
  deleteSource     Boolean   @default(false)
  status           String
  sourceJobId      String?
  targetJobId      String?
  cleanupJobId     String?
  error            String?
  warning          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  finishedAt       DateTime?

  @@unique([sourceWorktreeId, requestId])
  @@index([status, updatedAt])
  @@index([sourceJobId])
  @@index([targetJobId])
  @@index([cleanupJobId])
}

model WorktreeTag {
  id          String                  @id
  name        String                  @unique
  color       String
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  assignments WorktreeTagAssignment[]

  @@index([name])
}

model WorktreeTagAssignment {
  worktreeId String
  tagId      String
  worktree   Worktree    @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  tag        WorktreeTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([worktreeId, tagId])
  @@index([tagId])
}

model WorktreeSettings {
  id            String   @id
  editorVariant String   @default("CODE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ExternalMcpServer {
  id             String                    @id
  name           String                    @unique
  url            String
  transport      String
  toolNamePrefix String                    @default("")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  headers        ExternalMcpServerHeader[]

  @@index([name])
}

model ExternalMcpServerHeader {
  id        String            @id
  serverId  String
  name      String
  value     String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  server    ExternalMcpServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

model CcusageCollection {
  id         String                   @id
  deadlineAt DateTime
  finishedAt DateTime?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  agents     CcusageCollectionAgent[]
  jobs       AgentJob[]

  @@index([finishedAt, deadlineAt])
}

model CcusageCollectionAgent {
  collectionId  String
  agentId       String
  initialStatus String
  error         String?
  collection    CcusageCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  agent         Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([collectionId, agentId])
  @@index([agentId])
}

model AgentJobLog {
  id        String   @id
  jobId     String
  sequence  Int
  stream    String
  message   String
  createdAt DateTime @default(now())
  job       AgentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sequence])
  @@index([jobId, createdAt])
}

model AgentAuditEvent {
  id        String   @id
  agentId   String?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
}

model JiraSettings {
  id              String   @id
  siteUrl         String?
  email           String?
  apiToken        String?
  cacheTtlSeconds Int      @default(300)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JiraProject {
  id                     String       @id
  jiraId                 String       @unique
  key                    String       @unique
  name                   String
  avatarUrl              String?
  position               Int          @default(0)
  ticketAssignmentFilter String       @default("ALL")
  hideCompletedTickets   Boolean      @default(false)
  completedStatusIdsJson String       @default("[]")
  branchNamingScript     String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  sources                JiraSource[]
}

model JiraSource {
  id           String           @id
  projectId    String
  name         String
  kind         String
  value        String
  boardId      Int?
  position     Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      JiraProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cacheEntries JiraCacheEntry[]
  apiCalls     JiraApiCallLog[]

  @@unique([projectId, name])
  @@index([projectId, position])
}

model JiraCacheEntry {
  id           String                @id
  cacheKey     String                @unique
  operation    String
  paramsJson   String
  responseJson String
  fetchedAt    DateTime
  sourceId     String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  source       JiraSource?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  issues       JiraCacheEntryIssue[]

  @@index([operation, fetchedAt])
  @@index([sourceId, fetchedAt])
}

model JiraCachedTicket {
  issueKey          String                @id
  projectKey        String
  summaryJson       String?
  summaryFetchedAt  DateTime?
  detailJson        String?
  detailFetchedAt   DateTime?
  commentsJson      String?
  commentsFetchedAt DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  cacheEntries      JiraCacheEntryIssue[]

  @@index([projectKey, updatedAt])
  @@index([updatedAt])
}

model JiraCacheEntryIssue {
  cacheEntryId String
  issueKey     String
  cacheEntry   JiraCacheEntry   @relation(fields: [cacheEntryId], references: [id], onDelete: Cascade)
  ticket       JiraCachedTicket @relation(fields: [issueKey], references: [issueKey], onDelete: Cascade)

  @@id([cacheEntryId, issueKey])
  @@index([issueKey])
}

model JiraApiCallLog {
  id             String      @id
  operation      String
  requestSummary String
  source         String
  durationMs     Int
  statusCode     Int?
  error          String?
  itemCount      Int?
  servedStale    Boolean     @default(false)
  sourceId       String?
  createdAt      DateTime    @default(now())
  jiraSource     JiraSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([operation, source, createdAt])
  @@index([sourceId, createdAt])
}

model GitHubSettings {
  id                  String   @id
  apiToken            String?
  defaultJiraKeyRegex String   @default("\\b([A-Z][A-Z0-9_]*-\\d+)\\b")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GitHubAppSettings {
  id                  String   @id
  appId               String
  installationId      String
  privateKey          String
  apiBaseUrl          String   @default("https://api.github.com")
  graphqlUrl          String   @default("https://api.github.com/graphql")
  keyFingerprint      String
  appSlug             String
  accountLogin        String
  repositorySelection String
  actionsPermission   String
  verifiedAt          DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model GitHubAuditEvent {
  id              String   @id
  scopeId         String   @default("default")
  actor           String
  ipAddress       String?
  operation       String
  repositoryId    String?
  checkSuiteId    String?
  jobId           String?
  githubRequestId String?
  outcome         String
  errorCode       String?
  createdAt       DateTime @default(now())

  @@index([operation, createdAt])
  @@index([repositoryId, createdAt])
}

model GitHubRepository {
  id            String   @id
  githubId      String   @unique
  owner         String
  name          String
  nameWithOwner String   @unique
  url           String
  jiraKeyRegex  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([nameWithOwner])
}

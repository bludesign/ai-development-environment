{
  "version": "2.0.0",
  "options": {
    "env": {
      "PATH": "${env:HOME}/.asdf/shims:${env:PATH}"
    }
  },
  "tasks": [
    {
      "type": "shell",
      "label": "dev",
      "group": "build",
      "command": "npm run dev"
    },
    {
      "type": "shell",
      "label": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "command": "npm run build"
    },
    {
      "type": "shell",
      "label": "start",
      "group": "build",
      "command": "npm run start"
    },
    {
      "type": "shell",
      "label": "clean",
      "group": "build",
      "command": "npm run clean"
    },
    {
      "type": "shell",
      "label": "generate",
      "group": "build",
      "command": "npm run generate",
      "detail": "Run all code generation (Prisma, schema bundling, GraphQL codegen)"
    },
    {
      "type": "shell",
      "label": "generate:prisma",
      "group": "build",
      "command": "npm run generate:prisma",
      "detail": "Generate Prisma client"
    },
    {
      "type": "shell",
      "label": "generate:schema",
      "group": "build",
      "command": "npm run generate:schema",
      "detail": "Bundle GraphQL SDL files into TypeScript"
    },
    {
      "type": "shell",
      "label": "generate:graphql",
      "group": "build",
      "command": "npm run generate:graphql",
      "detail": "Generate GraphQL resolver types via codegen"
    },
    {
      "type": "shell",
      "label": "db:migrate",
      "group": "build",
      "command": "npm run db:migrate",
      "detail": "Create and apply Prisma migrations (dev)"
    },
    {
      "type": "shell",
      "label": "db:deploy",
      "group": "build",
      "command": "npm run db:deploy",
      "detail": "Apply pending Prisma migrations (production)"
    },
    {
      "type": "shell",
      "label": "db:studio",
      "group": "build",
      "command": "npm run db:studio",
      "detail": "Open Prisma Studio database browser"
    },
    {
      "type": "shell",
      "label": "supergraph",
      "group": "build",
      "command": "npm run supergraph",
      "detail": "Compose Apollo Federation supergraph via rover"
    },
    {
      "type": "shell",
      "label": "type-check",
      "group": "build",
      "command": "npm run type-check"
    },
    {
      "type": "shell",
      "label": "test-watch",
      "group": "test",
      "command": "npm test"
    },
    {
      "type": "shell",
      "label": "test",
      "group": "test",
      "command": "npm run test:run"
    },
    {
      "type": "shell",
      "label": "lint",
      "group": "test",
      "command": "npm run lint"
    },
    {
      "type": "shell",
      "label": "lint-fix",
      "group": "test",
      "command": "npm run lint:fix"
    },
    {
      "type": "shell",
      "label": "format",
      "group": "test",
      "command": "npm run format"
    },
    {
      "type": "shell",
      "label": "format-check",
      "group": "test",
      "command": "npm run format:check"
    },
    {
      "type": "shell",
      "label": "full-check",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "command": "npm run full-check"
    },
    {
      "type": "shell",
      "label": "full-check-ci",
      "group": "test",
      "command": "npm run full-check:ci"
    }
  ]
}

{
  "name": "ai-development-environment",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "scripts": {
    "dev": "npm run generate && npm run dev:generated",
    "dev:generated": "npm run db:migrate && next dev",
    "dev:all": "PORT=${PORT:-3000} AGENT_WS_HOSTNAME=${AGENT_WS_HOSTNAME:-127.0.0.1} AGENT_WS_PORT=${AGENT_WS_PORT:-3092} NEXT_PUBLIC_AGENT_WS_URL=${NEXT_PUBLIC_AGENT_WS_URL:-ws://127.0.0.1:${AGENT_WS_PORT:-3092}/graphql} concurrently --kill-others --names server,agent --prefix-colors blue,magenta \"npm run dev\" \"npm run agent:dev\"",
    "build": "npm run generate && npm run build:generated",
    "build:generated": "next build",
    "postbuild": "cp -R public .next/standalone/ && cp -R .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "agent:build": "npm run build --workspace @ai-development-environment/control-agent",
    "agent:dev": "npm run dev --workspace @ai-development-environment/control-agent",
    "agent:format": "npm run format --workspace @ai-development-environment/control-agent",
    "agent:format:check": "npm run format:check --workspace @ai-development-environment/control-agent",
    "agent:lint": "npm run lint --workspace @ai-development-environment/control-agent",
    "agent:lint:fix": "npm run lint:fix --workspace @ai-development-environment/control-agent",
    "agent:test": "npm run test --workspace @ai-development-environment/control-agent",
    "agent:test:run": "npm run test:run --workspace @ai-development-environment/control-agent",
    "agent:type-check": "npm run type-check --workspace @ai-development-environment/control-agent",
    "agent:full-check": "npm run full-check --workspace @ai-development-environment/control-agent",
    "agent:full-check:ci": "npm run full-check:ci --workspace @ai-development-environment/control-agent",
    "agent:full-check:dev": "npm run full-check:dev --workspace @ai-development-environment/control-agent",
    "generate": "npm run generate:prisma && npm run generate:schema && npm run generate:graphql",
    "generate:prisma": "prisma generate",
    "generate:schema": "tsx scripts/prebuild-schema.ts",
    "generate:graphql": "graphql-codegen --config codegen.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "supergraph": "rover supergraph compose --elv2-license accept --config ./supergraph.yaml > supergraph.graphql",
    "clean": "rm -rf .next coverage src/generated prisma/dev.db* supergraph.graphql",
    "format": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:check": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "pretype-check": "npm run generate",
    "type-check": "npm run type-check:generated",
    "type-check:generated": "tsc --noEmit && npm run agent:type-check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:standalone-credentials": "node scripts/test-standalone-credentials.mjs",
    "check-translations": "npx tsx scripts/check-translations.ts",
    "telemetry:mock": "tsx scripts/send-mock-telemetry.ts",
    "full-check": "npm run generate && npm run format && npm run lint:fix && npm run type-check:generated && npm run test:run && npm run agent:test:run && npm run check-translations && npm run build:generated && npm run postbuild",
    "full-check:ci": "npm run generate && npm run format:check && npm run lint && npm run type-check:generated && npm run test:run && npm run agent:test:run && npm run check-translations && npm run build:generated && npm run postbuild",
    "full-check:dev": "npm run full-check && npm run dev:generated",
    "upgrade": "ncu -u --cooldown 48h && npm install",
    "upgrade:check": "ncu --cooldown 48h"
  },
  "dependencies": {
    "@ai-development-environment/agent-contract": "*",
    "@apollo/server": "5.5.1",
    "@apollo/subgraph": "2.14.2",
    "@as-integrations/next": "4.1.0",
    "@base-ui/react": "1.6.0",
    "@expo-google-fonts/noto-emoji": "0.4.6",
    "@fontpkg/unifont": "15.0.1",
    "@graphql-tools/merge": "9.2.2",
    "@lobehub/icons-static-svg": "^1.94.0",
    "@mdx-js/loader": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@napi-rs/keyring": "1.3.0",
    "@next/mdx": "16.2.10",
    "@peculiar/x509": "2.0.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tailwindcss/typography": "0.5.20",
    "asn1js": "3.0.10",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "diff": "9.0.0",
    "extended-markdown-adf-parser": "2.4.0",
    "graphql": "^16",
    "graphql-tag": "2.12.7",
    "graphql-ws": "6.1.0",
    "jira.js": "5.4.0",
    "jira2md": "3.0.1",
    "jose": "6.2.3",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-intl": "4.13.2",
    "pdfkit": "0.19.1",
    "pkijs": "3.4.0",
    "quickjs-emscripten": "0.32.0",
    "radix-ui": "1.6.4",
    "re2-wasm": "1.0.2",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "recharts": "3.9.2",
    "reflect-metadata": "0.2.2",
    "remark-gfm": "4.0.1",
    "server-only": "0.0.1",
    "shadcn": "4.13.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "undici": "8.8.0",
    "web-push": "3.6.7",
    "ws": "8.21.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-resolvers": "6.1.0",
    "@mdx-js/rollup": "3.1.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "4.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^24",
    "@types/pdfkit": "0.17.6",
    "@types/react": "19.2",
    "@types/react-dom": "19.2",
    "@types/web-push": "3.6.4",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.9",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tailwindcss": "4.3",
    "tsx": "4.23.1",
    "typescript": "^6",
    "vitest": "4.1.10"
  },
  "optionalDependencies": {
    "@apollo/rover": "0.41.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "@apollo/protobufjs@1.2.8": true,
    "@parcel/watcher@2.6.0": true,
    "@prisma/engines@7.8.0": true,
    "@swc/core@1.15.46": true
  }
}

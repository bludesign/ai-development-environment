{
  "name": "ai-development-environment",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.16.0 <25"
  },
  "scripts": {
    "dev": "npm run generate && next dev",
    "build": "npm run generate && next build",
    "postbuild": "cp -R public .next/standalone/ && cp -R .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "generate": "npm run generate:prisma && npm run generate:schema && npm run generate:graphql",
    "generate:prisma": "prisma generate",
    "generate:schema": "tsx scripts/prebuild-schema.ts",
    "generate:graphql": "graphql-codegen --config codegen.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "supergraph": "rover supergraph compose --elv2-license accept --config ./supergraph.yaml > supergraph.graphql",
    "clean": "rm -rf .next coverage src/generated prisma/dev.db* supergraph.graphql",
    "format": "prettier --write --ignore-path .gitignore --ignore-path .prettierignore .",
    "format:check": "prettier --check --ignore-path .gitignore --ignore-path .prettierignore .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "full-check": "npm run generate && npm run format && npm run lint:fix && npm run type-check && npm run test:run && npm run build",
    "full-check:ci": "npm run generate && npm run format:check && npm run lint && npm run type-check && npm run test:run && npm run build",
    "full-check:dev": "npm run full-check && npm run dev",
    "upgrade": "ncu -u && npm install",
    "upgrade:check": "ncu"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@apollo/subgraph": "2.14.2",
    "@as-integrations/next": "4.1.0",
    "@graphql-tools/merge": "9.2.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-sqlite3": "12.11.1",
    "graphql": "^16",
    "graphql-tag": "2.12.7",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/typescript": "6.1.0",
    "@graphql-codegen/typescript-resolvers": "6.1.0",
    "@tailwindcss/postcss": "4.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^24",
    "@types/react": "19.2",
    "@types/react-dom": "19.2",
    "@vitejs/plugin-react": "6.0.3",
    "dotenv": "17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.9",
    "prettier": "3.9.5",
    "prisma": "7.8.0",
    "tailwindcss": "4.3",
    "tsx": "4.23.1",
    "typescript": "^6",
    "vitest": "4.1.10"
  },
  "optionalDependencies": {
    "@apollo/rover": "0.41.0"
  }
}
